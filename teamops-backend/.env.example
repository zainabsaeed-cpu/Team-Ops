PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/teamops
JWT_SECRET=change_this_to_a_secure_random_string
NODE_ENV=development
FRONTEND_URL=http://localhost:5174

# Email — leave blank to use Ethereal test previews (no real mail sent)
